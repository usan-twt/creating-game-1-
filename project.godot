; Engine configuration file.
; It's best edited using the editor UI and not directly,
; but the format is well-documented - https://docs.godotengine.org/en/stable/tutorials/misc/configuration_file.html

config_version=5

[application]

config/name="Intern"
config/description="의대 1년차 내러티브 게임"
run/main_scene="res://scenes/Main.tscn"
config/features=PackedStringArray("4.3", "Forward Plus")

[autoload]

GameManager="*res://scripts/core/GameManager.gd"
EpisodeData="*res://scripts/data/EpisodeData.gd"
EmotionData="*res://scripts/data/EmotionData.gd"
InterludeData="*res://scripts/data/InterludeData.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[rendering]

renderer/rendering_method="forward_plus"
